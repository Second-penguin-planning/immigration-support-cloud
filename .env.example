# =============================================================================
# Immigration Support Cloud - 環境変数テンプレート
# 実際の値は .env.local にコピーして設定する（.env.local はコミットしない）
# =============================================================================

# --- Database (PostgreSQL / Prisma) --------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/immigration_support_dev?schema=public"

# --- 個人情報の暗号化（旅券番号・在留カード番号等） -------------------------
# `openssl rand -base64 32` で生成した32byteの鍵（base64）。ローテーション時は
# 復号できなくなるため、本番では厳重に管理しバックアップを取ること。
ENCRYPTION_MASTER_KEY="replace-with-openssl-rand--base64-32-output"

# --- Auth.js --------------------------------------------------------------
# `openssl rand -base64 32` などで生成した32byte以上のランダム文字列
AUTH_SECRET="replace-with-a-random-32-byte-secret"
AUTH_URL="http://localhost:3000"

# --- メール送信（メール認証・パスワードリセット通知） -----------------------
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="apikey"
EMAIL_SERVER_PASSWORD="replace-me"
EMAIL_FROM="Immigration Support Cloud <no-reply@example.com>"

# --- ファイルストレージ（添付書類PDF等） -----------------------------------
# local: ローカルディスク保存（開発用のみ。Vercel等サーバーレス環境では永続化されないため本番非推奨）
# s3: S3互換オブジェクトストレージ（本番運用はこちらを使う。Phase8で実装、docs/07_deployment.md参照）
FILE_STORAGE_DRIVER="local"
FILE_STORAGE_LOCAL_DIR="./uploads"
# S3互換ストレージを使う場合（FILE_STORAGE_DRIVER=s3のとき必須）
# S3_ENDPOINTはAWS S3本体を使う場合は空のままでよい（MinIO等S3互換ストレージのみ設定）
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="ap-northeast-1"

# --- AI補助機能（OCR・PDF読取・入力候補） ----------------------------------
ANTHROPIC_API_KEY="replace-with-anthropic-api-key"

# --- アプリケーション全般 ---------------------------------------------------
NODE_ENV="development"
APP_BASE_URL="http://localhost:3000"
